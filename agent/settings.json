  "showHardwareCursor": false,
  "editorPaddingX": 0,
  "showCacheMissNotices": true,
  "steeringMode": "one-at-a-time",
  "defaultProjectTrust": "always",
  "doubleEscapeAction": "tree",
  "hideThinkingBlock": false
}